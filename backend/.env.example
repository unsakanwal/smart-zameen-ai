# Copy this file to ".env" and fill in your real values.
# .env is gitignored and must NEVER be committed.

# Database — leave UNSET for local SQLite (zero setup). In production set this to
# your Neon connection string and the app uses Postgres instead (persistent).
# Get it from neon.tech -> your project -> "Connection string" (include sslmode).
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# OpenAI — powers the whole assistant: chat (text + image/vision + files) and
# voice (Whisper speech-to-text). Required for chat + voice to work.
OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini         # optional chat-model override (vision-capable)
# OPENAI_WHISPER_MODEL=whisper-1   # optional speech-to-text model override

# OpenWeatherMap — real weather data (required for the Weather page)
WEATHER_API_KEY=your_openweather_key_here

# Twilio — WhatsApp + SMS chatbot
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here
TWILIO_PHONE=+14155238886
