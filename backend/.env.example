# Copy this file to ".env" and fill in your real values.
# .env is gitignored and must NEVER be committed.

# OpenAI — Crop Advisor chat (text + image/vision + voice + files)
OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini      # optional override (vision-capable)

# Anthropic Claude — soil image analysis (optional)
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenWeatherMap — real weather data (omit to use built-in mock data)
WEATHER_API_KEY=your_openweather_key_here

# Twilio — WhatsApp + SMS chatbot
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here
TWILIO_PHONE=+14155238886
